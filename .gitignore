# ---- Generated data & run outputs ----
# data/raw is local input territory; we track only the small, irreplaceable
# assembled scaffold complex so the repo is runnable out-of-the-box.
data/raw/*
!data/raw/.gitkeep
!data/raw/scaffold_complex.pdb
data/processed/*
!data/processed/.gitkeep
outputs/
samples/

# Stray PDBs / logs at repo root
/*.pdb
/*.log
